# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
# Optional: limit pool size (default 2 on Vercel to avoid max_user_connections)
# DB_CONNECTION_LIMIT=2

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here

# CORS (comma-separated origins; include field attendance web app port if used)
# On Vercel: include your live frontend origin(s), e.g. https://crm.aksuccessrobotics.com.my and any Vercel preview URLs you use.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Client site visit geofence (Haversine + slack on server)
CLIENT_GEOFENCE_RADIUS_M=1000
GEOFENCE_SLACK_M=100
CLIENT_GEOCODE_MAX_ACCURACY_M=200
# Optional: Google Geocoding (else OSM Nominatim is used from backend)
# GOOGLE_MAPS_API_KEY=

# SMTP (password reset, notifications, billing request)
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# Billing request emails (comma-separated)
ACCOUNTS_TEAM_EMAILS=wanz@aksuccess.com.my,it@aksuccess.com.my,andy@aksuccess.com.my,mugun@aksuccess.com.my

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
# CLIENT_URL=http://localhost:5173

# Password reset
RESET_PASSWORD_BASE_URL=http://localhost:5173
RESET_TOKEN_EXPIRES_MINUTES=30
RESET_TOKEN_BYTES=32
FORGOT_RATE_LIMIT_IP_MAX=5
FORGOT_RATE_LIMIT_IP_WINDOW_MINUTES=15
FORGOT_RATE_LIMIT_EMAIL_MAX=3
FORGOT_RATE_LIMIT_EMAIL_WINDOW_MINUTES=30

# Debug login (set 0 in production)
DEBUG_LOGIN=0
# DEBUG_LOGIN_EMAIL=test@example.com
# DEBUG_LOGIN_PASSWORD=secret

# --- Vercel ---
# Copy these keys into Vercel → Project → Settings → Environment Variables (Production).
# Frontend/APK: VITE_API_URL should be https://aksr-crm.vercel.app/api (see frontend/.env.production).
# Deploy API: from backend folder run  npm run deploy:vercel  (uses repo root as cwd; do not run plain
# `vercel` only inside backend/ if the linked project Root Directory is `backend` — that causes a path error).
