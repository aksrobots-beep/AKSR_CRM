# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173

# SMTP (password reset, notifications, billing request)
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# Billing request emails (comma-separated)
ACCOUNTS_TEAM_EMAILS=aksrobots@gmail.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
# CLIENT_URL=http://localhost:5173

# Password reset
RESET_PASSWORD_BASE_URL=http://localhost:5173
RESET_TOKEN_EXPIRES_MINUTES=30
RESET_TOKEN_BYTES=32
FORGOT_RATE_LIMIT_IP_MAX=5
FORGOT_RATE_LIMIT_IP_WINDOW_MINUTES=15
FORGOT_RATE_LIMIT_EMAIL_MAX=3
FORGOT_RATE_LIMIT_EMAIL_WINDOW_MINUTES=30

# Debug login (set 0 in production)
DEBUG_LOGIN=0
# DEBUG_LOGIN_EMAIL=test@example.com
# DEBUG_LOGIN_PASSWORD=secret
